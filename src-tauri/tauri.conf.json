{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skill Control",
  "version": "0.1.0",
  "identifier": "com.skillcontrol.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skill Control",
        "width": 1440,
        "height": 940,
        "minWidth": 1040,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
